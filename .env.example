# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=campaign_manager
DB_USER=postgres
DB_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-dev-key-for-docker-compose

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── SMTP (Mailpit sandbox — replace for production) ───────────────────────────
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=campaign-manager@localhost

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
